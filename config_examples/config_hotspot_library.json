{
  "job": {
    "area_name": "pivo"
  },
  "aoi": {
    "source": "url",
    "url": "https://facilita.public.blob.vercel-storage.com/zonas-manejo/pivo_contorno.kml",
    "layer": "contour"
  },
  "rasters": [
    {
      "attribute": "P",
      "source": "url",
      "url": "https://facilita.public.blob.vercel-storage.com/zonas-manejo/P_10m.tif"
    },
    {
      "attribute": "Ca",
      "source": "url",
      "url": "https://facilita.public.blob.vercel-storage.com/zonas-manejo/Ca_10m.tif"
    }
  ],
  "mode": "hotspot",
  "user_choices": {
    "min_zone_area_ha": 2.0
  },
  "mode_params": {
    "hotspot_mode": "library",
    "selected_attributes": ["P", "Ca"],
    "classification_library": {
      "attributes": {
        "P": {
          "unit": "mg/dm3",
          "levels": [
            { "level": "critico", "max": 30.0, "score": 0 },
            { "level": "medio", "min": 30.0, "max": 45.0, "score": 2 },
            { "level": "bom", "min": 45.0, "score": 3 }
          ]
        },
        "Ca": {
          "unit": "mmolc/dm3",
          "levels": [
            { "level": "critico", "max": 20.0, "score": 0 },
            { "level": "medio", "min": 20.0, "max": 30.0, "score": 2 },
            { "level": "bom", "min": 30.0, "score": 3 }
          ]
        }
      }
    }
  },
  "output": {
    "format": "gpkg",
    "include_stats": true,
    "include_quicklooks": true
  }
}
