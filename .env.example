# Endpoint do Facilita usado para resolver blobs e notificar o add_raster_interpolados
FACILITAGRO_FRONTEND_BASE_URL=https://facilitagro.com.br

# Token do Blob Storage (preencha ao menos um dos dois, conforme o ambiente)
BLOB_READ_WRITE_TOKEN=seu_token_blob_aqui
NEXT_PUBLIC_BLOB_READ_WRITE_TOKEN=

# URLs opcionais para override do serviço de Blob
BLOB_UPLOAD_BASE_URL=https://blob.vercel-storage.com
BLOB_STORAGE_UPLOAD_BASE_URL=
BLOB_STORAGE_BASE_URL=
